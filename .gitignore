# Python
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# macOS
.DS_Store

# Audio: never commit the raw sets. They are large and re-fetchable from
# configs/sets.csv via `python -m src.acquire`. Keep the folders via .gitkeep.
data/raw/*
data/interim/*
data/processed/*
!data/**/.gitkeep

# Model artifacts are big and reproducible by re-training.
*.pt
*.ckpt

# Outputs are regenerated; commit only curated figures I choose to add.
outputs/*
!outputs/.gitkeep

# Exception: commit the two small derived artifacts the deployed app needs so it
# runs on Streamlit Cloud without the raw audio. These are tiny (a feature table
# and a 75K model), reproducible, and contain no actual music.
!data/processed/vibes.parquet
!outputs/lstm.pt
